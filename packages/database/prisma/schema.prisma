// StatTracker database schema
// Postgres 16 + Prisma 6

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity ────────────────────────────

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  emailVerified DateTime?
  displayName   String?
  avatarUrl     String?
  image         String?
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts     Account[]
  sessions     Session[]
  riotAccounts RiotAccount[]

  @@map("users")
}

// ─── NextAuth / Auth.js models ──────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Riot platform linkage ───────────────

model RiotAccount {
  id           String   @id @default(cuid())
  userId       String
  puuid        String   @unique
  gameName     String
  tagLine      String
  region       String
  linkedAt     DateTime @default(now())
  lastSyncedAt DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches      MatchSnapshot[]

  @@index([userId])
  @@index([gameName, tagLine])
  @@map("riot_accounts")
}

// ─── Per-match snapshots (LoL first) ─────

model MatchSnapshot {
  id            String      @id @default(cuid())
  riotAccountId String
  matchId       String
  game          Game
  queue         String?
  gameMode      String?
  championId    Int?
  championName  String?
  teamPosition  String?
  win           Boolean
  kills         Int
  deaths        Int
  assists       Int
  durationSec   Int
  playedAt      DateTime
  raw           Json?
  createdAt     DateTime    @default(now())

  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id], onDelete: Cascade)

  @@unique([riotAccountId, matchId])
  @@index([game, playedAt])
  @@index([riotAccountId, playedAt])
  @@map("match_snapshots")
}

// ─── Per-patch aggregated champion stats ─

model ChampionStat {
  id           String   @id @default(cuid())
  game         Game
  patch        String
  championKey  String
  role         String?
  winrate      Float
  pickrate     Float
  banrate      Float?
  tier         String?
  sampleSize   Int      @default(0)
  computedAt   DateTime @default(now())

  @@unique([game, patch, championKey, role])
  @@index([game, patch])
  @@map("champion_stats")
}

enum Game {
  LOL
  TFT
  VALORANT
  DOTA2
  DEADLOCK
  TWOXKO
  WOW
  HELLDIVERS2
  REMATCH
}
