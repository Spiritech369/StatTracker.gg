# ─── Database ─────────────────────────────
DATABASE_URL="postgresql://trackerstat:trackerstat@localhost:5432/trackerstat?schema=public"

# ─── Redis ────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── API ──────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_CORS_ORIGIN=http://localhost:9090

# ─── Web ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Auth (NextAuth v5 / Auth.js) ─────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:9090
# Shared with API so it can decode session JWTs
AUTH_TRUST_HOST=true

# Discord OAuth (https://discord.com/developers/applications)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# ─── Riot API (get from https://developer.riotgames.com/) ────
RIOT_API_KEY=
